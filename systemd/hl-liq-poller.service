[Unit]
Description=HL Reaper liquidation event collector (mainnet, read-only, Phase 8.6)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=veilcerpin
WorkingDirectory=/opt/hl-reaper
ExecStart=/opt/hl-reaper/venv/bin/python /opt/hl-reaper/scripts/run_liquidation_poller.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
